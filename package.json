{
  "name": "fintech-production-support-lab",
  "version": "0.1.0",
  "description": "Synthetic fintech production-support lab for investigating mock payment incidents with SQL, vendor events, and support-ready audit reports.",
  "private": false,
  "type": "module",
  "scripts": {
    "api": "tsx src/index.ts api --port 3000",
    "build": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "investigate": "tsx src/index.ts investigate TCK-1001",
    "investigate:ach": "tsx src/index.ts investigate TCK-1002",
    "lint": "tsc --noEmit",
    "report": "tsx src/index.ts investigate TCK-1001 --write",
    "report:ach": "tsx src/index.ts investigate TCK-1002 --write",
    "reports": "npm run report && npm run report:ach && npm run report:stale-holds",
    "report:stale-holds": "tsx src/index.ts stale-holds --write",
    "stale-holds": "tsx src/index.ts stale-holds",
    "test": "vitest run",
    "verify": "npm run build && npm run test && npm run investigate && npm run investigate:ach && npm run stale-holds"
  },
  "keywords": [
    "fintech",
    "production-support",
    "typescript",
    "sql",
    "payments",
    "support-engineering"
  ],
  "author": "Sabastian Angulo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
